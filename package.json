{
  "name": "cipher",
  "version": "0.1.0",
  "private": true,
  "description": "Cipher — messenger E2EE descentralizat (Android, Expo). Faza UI + arhitectura; crypto/transport mockate in spatele interfetelor reale.",
  "main": "expo-router/entry",
  "overrides": {
